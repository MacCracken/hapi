# hapi — main entry point.
#
# Argv dispatcher. Ten verbs frozen at v1.0.0; --version /
# --help round out the surface. Global flags landed in M6:
#   --root <path>  — open a non-$HOME scope, gated by ADR 0005
#                    (HAPI_ALLOWED_ROOTS stopgap, kavach later).
#                    Accepted on: link, adopt, status, list, sync.
#   --dry-run      — show what would happen; no syscalls or
#                    audit writes. Accepted on: link, unlink,
#                    adopt, sync, rollback, checkpoint.
# M7 added:
#   --backup-to <dir> — snapshot the existing on-disk file
#                    before a destructive overwrite (link --force
#                    / sync / adopt). Audit entry gains an
#                    additive `backup_path` field per ADR 0002's
#                    growth contract. Accepted on: link, sync,
#                    adopt.
#
# The exit-code contract:
#   0  success
#   1  command-specific failure (parse error, conflict, IO,
#      capability denial)
#   2  bad usage (unknown verb, unknown / misplaced flag,
#      missing argument)

include "src/agnos_compat.cyr"
include "src/cmd/inspect.cyr"
include "src/cmd/link.cyr"
include "src/cmd/unlink.cyr"
include "src/cmd/adopt.cyr"
include "src/cmd/rollback.cyr"
include "src/cmd/checkpoint.cyr"
include "src/cmd/status.cyr"
include "src/cmd/list.cyr"
include "src/cmd/check.cyr"
include "src/cmd/sync.cyr"
include "src/cli.cyr"
include "src/cap.cyr"
include "src/backup.cyr"
include "lib/args.cyr"

# VERSION literal kept in sync with the VERSION file at the
# project root. CLAUDE.md's work loop calls out "version sync"
# explicitly — bump this string in the same commit as VERSION.
fn hapi_print_version(): i64 {
    println("hapi 1.0.3");
    return 0;
}

fn hapi_print_usage(): i64 {
    println("usage: hapi <command> [args...]");
    println("");
    println("commands:");
    println("  inspect <path>            parse and display a package manifest");
    println("  link <path> [--force]     create symlinks for the package");
    println("  unlink <pkg>              remove this package's symlinks from the trail");
    println("  adopt <file> <pkg>        move a file into a package, link back");
    println("  rollback                  reverse the audit trail to the last marker");
    println("  checkpoint                append a rollback-marker to the audit trail");
    println("  status <path>             show drift between manifest and on-disk symlinks");
    println("  list                      list packages tracked in the audit trail");
    println("  check <path> [--strict]   parse + display a manifest, optionally strict");
    println("  sync <path>               re-apply a manifest (idempotent)");
    println("");
    println("global flags:");
    println("  --root <path>             open a non-$HOME scope (link/adopt/status/list/sync)");
    println("                            requires the path to be inside $HOME or listed");
    println("                            in HAPI_ALLOWED_ROOTS (colon-separated)");
    println("  --dry-run                 print actions; no syscalls or audit writes");
    println("                            (link/unlink/adopt/sync/rollback/checkpoint)");
    println("  --backup-to <dir>         snapshot existing file content to <dir> before");
    println("                            a destructive overwrite (link --force / sync /");
    println("                            adopt). Audit entry gains `backup_path`.");
    println("");
    println("options:");
    println("  --version, -v             print version and exit");
    println("  --help, -h                print this message and exit");
    return 0;
}

# Compare an argv cstring to a literal cstring (both null-terminated).
fn _hapi_argeq(arg, lit): i64 {
    if (arg == 0) { return 0; }
    var la = strlen(arg);
    var ll = strlen(lit);
    if (la != ll) { return 0; }
    return memeq(arg, lit, la);
}

# True if `arg` looks like a flag (starts with '-'). Used to
# guard against an unrecognized flag being swallowed as a
# positional argument.
fn _hapi_is_flag(arg): i64 {
    if (arg == 0) { return 0; }
    if (strlen(arg) < 1) { return 0; }
    if (load8(arg) == 45) { return 1; }
    return 0;
}

# Apply a `--root <value>` pair: cap-check the value, set the
# scope override on success. Returns 0 success / 1 cap denial
# / 2 missing value.
fn _hapi_apply_root(value): i64 {
    if (value == 0 || strlen(value) == 0) {
        eprint("hapi: --root requires a path argument\n", 39);
        return 2;
    }
    var cr = cap_check_root_r(value);
    if (is_err_result(cr) == 1) {
        var code = load64(cr + 8);
        var msg = hapi_cap_err_msg(code);
        eprint("hapi: ", 6);
        eprint(msg, strlen(msg));
        eprint("\n", 1);
        return 1;
    }
    var abs_root = load64(cr + 8);
    link_set_scope_root(abs_root);
    return 0;
}

# Print a stock "unexpected flag for this verb" error.
fn _hapi_unexpected_flag(verb, flag): i64 {
    eprint("hapi: unexpected flag for `", 27);
    eprint(verb, strlen(verb));
    eprint("`: ", 3);
    eprint(flag, strlen(flag));
    eprint("\n", 1);
    return 0;
}

fn main(): i64 {
    alloc_init();
    args_init();

    var n = argc();
    if (n < 2) {
        hapi_print_usage();
        return 2;
    }

    var verb = argv(1);

    if (_hapi_argeq(verb, "--version") == 1) { return hapi_print_version(); }
    if (_hapi_argeq(verb, "-v") == 1)        { return hapi_print_version(); }
    if (_hapi_argeq(verb, "--help") == 1)    { return hapi_print_usage(); }
    if (_hapi_argeq(verb, "-h") == 1)        { return hapi_print_usage(); }

    if (_hapi_argeq(verb, "inspect") == 1) {
        var path = 0;
        if (n >= 3) { path = argv(2); }
        return cmd_inspect(path);
    }

    if (_hapi_argeq(verb, "link") == 1) {
        var path = 0;
        var force = 0;
        var ai = 2;
        while (ai < n) {
            var a = argv(ai);
            if (_hapi_argeq(a, "--force") == 1) { force = 1; }
            elif (_hapi_argeq(a, "--dry-run") == 1) { hapi_set_dry_run(1); }
            elif (_hapi_argeq(a, "--root") == 1) {
                var v = 0;
                if (ai + 1 < n) { v = argv(ai + 1); }
                var rc = _hapi_apply_root(v);
                if (rc != 0) { return rc; }
                ai = ai + 1;
            }
            elif (_hapi_argeq(a, "--backup-to") == 1) {
                if (ai + 1 >= n) {
                    eprint("hapi: --backup-to requires a directory argument\n", 49);
                    return 2;
                }
                hapi_set_backup_dir(argv(ai + 1));
                ai = ai + 1;
            }
            elif (_hapi_is_flag(a) == 1) { _hapi_unexpected_flag(verb, a); return 2; }
            elif (path == 0) { path = a; }
            ai = ai + 1;
        }
        return cmd_link(path, force);
    }

    if (_hapi_argeq(verb, "unlink") == 1) {
        var pkg = 0;
        var ai = 2;
        while (ai < n) {
            var a = argv(ai);
            if (_hapi_argeq(a, "--dry-run") == 1) { hapi_set_dry_run(1); }
            elif (_hapi_is_flag(a) == 1) { _hapi_unexpected_flag(verb, a); return 2; }
            elif (pkg == 0) { pkg = a; }
            ai = ai + 1;
        }
        return cmd_unlink(pkg);
    }

    if (_hapi_argeq(verb, "adopt") == 1) {
        var file = 0;
        var pkg = 0;
        var ai = 2;
        while (ai < n) {
            var a = argv(ai);
            if (_hapi_argeq(a, "--dry-run") == 1) { hapi_set_dry_run(1); }
            elif (_hapi_argeq(a, "--root") == 1) {
                var v = 0;
                if (ai + 1 < n) { v = argv(ai + 1); }
                var rc = _hapi_apply_root(v);
                if (rc != 0) { return rc; }
                ai = ai + 1;
            }
            elif (_hapi_argeq(a, "--backup-to") == 1) {
                if (ai + 1 >= n) {
                    eprint("hapi: --backup-to requires a directory argument\n", 49);
                    return 2;
                }
                hapi_set_backup_dir(argv(ai + 1));
                ai = ai + 1;
            }
            elif (_hapi_is_flag(a) == 1) { _hapi_unexpected_flag(verb, a); return 2; }
            elif (file == 0) { file = a; }
            elif (pkg == 0) { pkg = a; }
            ai = ai + 1;
        }
        return cmd_adopt(file, pkg);
    }

    if (_hapi_argeq(verb, "rollback") == 1) {
        var ai = 2;
        while (ai < n) {
            var a = argv(ai);
            if (_hapi_argeq(a, "--dry-run") == 1) { hapi_set_dry_run(1); }
            elif (_hapi_is_flag(a) == 1) { _hapi_unexpected_flag(verb, a); return 2; }
            ai = ai + 1;
        }
        return cmd_rollback();
    }

    if (_hapi_argeq(verb, "checkpoint") == 1) {
        var ai = 2;
        while (ai < n) {
            var a = argv(ai);
            if (_hapi_argeq(a, "--dry-run") == 1) { hapi_set_dry_run(1); }
            elif (_hapi_is_flag(a) == 1) { _hapi_unexpected_flag(verb, a); return 2; }
            ai = ai + 1;
        }
        return cmd_checkpoint();
    }

    if (_hapi_argeq(verb, "status") == 1) {
        var path = 0;
        var ai = 2;
        while (ai < n) {
            var a = argv(ai);
            if (_hapi_argeq(a, "--root") == 1) {
                var v = 0;
                if (ai + 1 < n) { v = argv(ai + 1); }
                var rc = _hapi_apply_root(v);
                if (rc != 0) { return rc; }
                ai = ai + 1;
            }
            elif (_hapi_is_flag(a) == 1) { _hapi_unexpected_flag(verb, a); return 2; }
            elif (path == 0) { path = a; }
            ai = ai + 1;
        }
        return cmd_status(path);
    }

    if (_hapi_argeq(verb, "list") == 1) {
        var ai = 2;
        while (ai < n) {
            var a = argv(ai);
            if (_hapi_argeq(a, "--root") == 1) {
                var v = 0;
                if (ai + 1 < n) { v = argv(ai + 1); }
                var rc = _hapi_apply_root(v);
                if (rc != 0) { return rc; }
                ai = ai + 1;
            }
            elif (_hapi_is_flag(a) == 1) { _hapi_unexpected_flag(verb, a); return 2; }
            ai = ai + 1;
        }
        return cmd_list();
    }

    if (_hapi_argeq(verb, "sync") == 1) {
        var path = 0;
        var ai = 2;
        while (ai < n) {
            var a = argv(ai);
            if (_hapi_argeq(a, "--dry-run") == 1) { hapi_set_dry_run(1); }
            elif (_hapi_argeq(a, "--root") == 1) {
                var v = 0;
                if (ai + 1 < n) { v = argv(ai + 1); }
                var rc = _hapi_apply_root(v);
                if (rc != 0) { return rc; }
                ai = ai + 1;
            }
            elif (_hapi_argeq(a, "--backup-to") == 1) {
                if (ai + 1 >= n) {
                    eprint("hapi: --backup-to requires a directory argument\n", 49);
                    return 2;
                }
                hapi_set_backup_dir(argv(ai + 1));
                ai = ai + 1;
            }
            elif (_hapi_is_flag(a) == 1) { _hapi_unexpected_flag(verb, a); return 2; }
            elif (path == 0) { path = a; }
            ai = ai + 1;
        }
        return cmd_sync(path);
    }

    if (_hapi_argeq(verb, "check") == 1) {
        var path = 0;
        var strict = 0;
        var ai = 2;
        while (ai < n) {
            var a = argv(ai);
            if (_hapi_argeq(a, "--strict") == 1) { strict = 1; }
            elif (_hapi_is_flag(a) == 1) { _hapi_unexpected_flag(verb, a); return 2; }
            elif (path == 0) { path = a; }
            ai = ai + 1;
        }
        return cmd_check(path, strict);
    }

    eprint("hapi: unknown command: ", 23);
    eprint(verb, strlen(verb));
    eprint("\n", 1);
    hapi_print_usage();
    return 2;
}

var r = main();
syscall(SYS_EXIT, r);
