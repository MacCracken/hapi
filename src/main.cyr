# hapi — main entry point.
#
# Argv dispatcher. At M1 the only verb is `inspect`; `--version`
# and `--help` are wired up so the binary's surface matches a
# real CLI from day one. M2+ verbs (link / unlink / adopt / sync /
# list / status / rollback) plug into the same dispatch table.
#
# The exit-code contract:
#   0  success
#   1  command-specific failure (parse error, conflict, IO error)
#   2  bad usage (unknown verb, missing argument)
#
# Capability-bounded execution lands in M6 — until then, every
# verb is implicitly $HOME-scoped (no `--root` yet).

include "src/cmd/inspect.cyr"
include "src/cmd/link.cyr"
include "src/cmd/unlink.cyr"
include "src/cmd/rollback.cyr"
include "lib/args.cyr"

# VERSION literal kept in sync with the VERSION file at the
# project root. CLAUDE.md's work loop calls out "version sync"
# explicitly — bump this string in the same commit as VERSION.
fn hapi_print_version(): i64 {
    println("hapi 0.4.0");
    return 0;
}

fn hapi_print_usage(): i64 {
    println("usage: hapi <command> [args...]");
    println("");
    println("commands:");
    println("  inspect <path>            parse and display a package manifest");
    println("  link <path> [--force]     create symlinks for the package");
    println("  unlink <pkg>              remove this package's symlinks from the trail");
    println("  rollback                  reverse the audit trail to the last marker");
    println("");
    println("options:");
    println("  --version, -v             print version and exit");
    println("  --help, -h                print this message and exit");
    return 0;
}

# Compare an argv cstring to a literal cstring (both null-terminated).
fn _hapi_argeq(arg, lit): i64 {
    if (arg == 0) { return 0; }
    var la = strlen(arg);
    var ll = strlen(lit);
    if (la != ll) { return 0; }
    return memeq(arg, lit, la);
}

fn main(): i64 {
    alloc_init();
    args_init();

    var n = argc();
    if (n < 2) {
        hapi_print_usage();
        return 2;
    }

    var verb = argv(1);

    if (_hapi_argeq(verb, "--version") == 1) { return hapi_print_version(); }
    if (_hapi_argeq(verb, "-v") == 1)        { return hapi_print_version(); }
    if (_hapi_argeq(verb, "--help") == 1)    { return hapi_print_usage(); }
    if (_hapi_argeq(verb, "-h") == 1)        { return hapi_print_usage(); }

    if (_hapi_argeq(verb, "inspect") == 1) {
        var path = 0;
        if (n >= 3) { path = argv(2); }
        return cmd_inspect(path);
    }

    if (_hapi_argeq(verb, "link") == 1) {
        var path = 0;
        var force = 0;
        var ai = 2;
        while (ai < n) {
            var a = argv(ai);
            if (_hapi_argeq(a, "--force") == 1) { force = 1; }
            elif (path == 0) { path = a; }
            ai = ai + 1;
        }
        return cmd_link(path, force);
    }

    if (_hapi_argeq(verb, "unlink") == 1) {
        var pkg = 0;
        if (n >= 3) { pkg = argv(2); }
        return cmd_unlink(pkg);
    }

    if (_hapi_argeq(verb, "rollback") == 1) {
        return cmd_rollback();
    }

    eprint("hapi: unknown command: ", 23);
    eprint(verb, strlen(verb));
    eprint("\n", 1);
    hapi_print_usage();
    return 2;
}

var r = main();
syscall(SYS_EXIT, r);
