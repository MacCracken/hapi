    assert_eq(live, 3, "3 live links after link");

    cmd_unlink("dotfiles-zsh");
    var trail2 = audit_read_default();
    var live2 = _hls_live_count(trail2, "dotfiles-zsh");
    assert_eq(live2, 0, "0 live links after unlink");

    cmd_link("docs/examples/dotfiles-zsh", 0);
    var trail3 = audit_read_default();
    var live3 = _hls_live_count(trail3, "dotfiles-zsh");
    assert_eq(live3, 3, "3 live links after re-link");

    _test_clear_env();
    return 0;
}

