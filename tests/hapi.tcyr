# Convenience: parse a literal manifest string and assert it
# returned Err(<expected>). `expected` is one of the HapiMf*
# enum values.
fn _expect_err(label, src, expected): i64 {
    var r = hapi_mf_parse_header_r(src, strlen(src));
    if (is_err_result(r) == 1) {
        assert_eq(load64(r + 8), expected, label);
    } else {
        assert(0, label);
    }
    return 0;
}

fn _expect_ok(label, src): i64 {
    var r = hapi_mf_parse_header_r(src, strlen(src));
    assert_eq(is_ok(r), 1, label);
    return 0;
}

# Str-vs-cstring equality check. assert_streq in lib/assert.cyr is
# cstring-vs-cstring; our Str values aren't null-terminated, so we
# go through str_eq_cstr instead.
fn _assert_str_eq_cstr(s: Str, cstr, name): i64 {
    assert(str_eq_cstr(s, cstr), name);
    return 0;
}

fn test_minimal_manifest() {
    test_group("manifest: minimal happy path");

    var src = "[package]\nname = \"pkg\"\nversion = \"0.1.0\"\n";
    var r = hapi_mf_parse_header_r(src, strlen(src));
    assert_eq(is_ok(r), 1, "minimal manifest parses");
    var m = load64(r + 8);
    _assert_str_eq_cstr(hapi_mf_name(m), "pkg", "name = pkg");
    _assert_str_eq_cstr(hapi_mf_version(m), "0.1.0", "version = 0.1.0");
    assert_eq(hapi_mf_description(m), 0, "description is absent");
    assert_eq(vec_len(hapi_mf_links(m)), 0, "no link rows");
    assert_eq(vec_len(hapi_mf_ignore(m)), 0, "no ignore patterns");
    return 0;
}

fn test_three_links() {
    test_group("manifest: 3-link package (M1 acceptance)");

    var src = "[package]\nname = \"dotfiles-zsh\"\nversion = \"1.0.0\"\ndescription = \"zsh\"\nignore = [\"*.bak\", \".DS_Store\"]\n\n[[link]]\nsource = \"zshrc\"\ntarget = \".zshrc\"\n\n[[link]]\nsource = \"zshenv\"\ntarget = \".zshenv\"\n\n[[link]]\nsource = \"config/zsh\"\ntarget = \".config/zsh\"\n";
    var r = hapi_mf_parse_header_r(src, strlen(src));
    assert_eq(is_ok(r), 1, "parses cleanly");
    var m = load64(r + 8);
    _assert_str_eq_cstr(hapi_mf_name(m), "dotfiles-zsh", "package.name");
    _assert_str_eq_cstr(hapi_mf_version(m), "1.0.0", "package.version");
    _assert_str_eq_cstr(hapi_mf_description(m), "zsh", "package.description");

    var links = hapi_mf_links(m);
    assert_eq(vec_len(links), 3, "three link rows");
    var l0 = vec_get(links, 0);
    _assert_str_eq_cstr(hapi_link_source(l0), "zshrc", "link[0].source");
    _assert_str_eq_cstr(hapi_link_target(l0), ".zshrc", "link[0].target");
    var l2 = vec_get(links, 2);
    _assert_str_eq_cstr(hapi_link_source(l2), "config/zsh", "link[2].source");
    _assert_str_eq_cstr(hapi_link_target(l2), ".config/zsh", "link[2].target");

    var ignore = hapi_mf_ignore(m);
    assert_eq(vec_len(ignore), 2, "two ignore patterns");
    _assert_str_eq_cstr(vec_get(ignore, 0), "*.bak", "ignore[0]");
    _assert_str_eq_cstr(vec_get(ignore, 1), ".DS_Store", "ignore[1]");
    return 0;
}

fn test_validation_errors() {
    test_group("manifest: validation errors");

    _expect_err("missing name",
        "[package]\nversion = \"1.0\"\n",
        HapiMfMissingName);

    _expect_err("missing version",
        "[package]\nname = \"x\"\n",
        HapiMfMissingVersion);

    _expect_err("empty name",
        "[package]\nname = \"\"\nversion = \"1.0\"\n",
        HapiMfMissingName);

    _expect_err("missing link source",
        "[package]\nname = \"x\"\nversion = \"1.0\"\n[[link]]\ntarget = \"a\"\n",
        HapiMfMissingSource);

    _expect_err("missing link target",
        "[package]\nname = \"x\"\nversion = \"1.0\"\n[[link]]\nsource = \"a\"\n",
        HapiMfMissingTarget);

    _expect_err("duplicate target",
        "[package]\nname = \"x\"\nversion = \"1.0\"\n[[link]]\nsource = \"a\"\ntarget = \".same\"\n[[link]]\nsource = \"b\"\ntarget = \".same\"\n",
        HapiMfDuplicateTarget);
    return 0;
}

fn test_path_traversal() {
    test_group("manifest: path traversal rejected");

    _expect_err("source has ..",
        "[package]\nname = \"x\"\nversion = \"1.0\"\n[[link]]\nsource = \"../etc\"\ntarget = \".x\"\n",
        HapiMfPathTraversal);

    _expect_err("target has ..",
        "[package]\nname = \"x\"\nversion = \"1.0\"\n[[link]]\nsource = \"a\"\ntarget = \"../.bashrc\"\n",
        HapiMfPathTraversal);

    _expect_err(".. in middle of target",
        "[package]\nname = \"x\"\nversion = \"1.0\"\n[[link]]\nsource = \"a\"\ntarget = \"a/../b\"\n",
        HapiMfPathTraversal);

    # A leading dot file (not a `..` segment) is fine.
    _expect_ok("leading-dot target is fine",
        "[package]\nname = \"x\"\nversion = \"1.0\"\n[[link]]\nsource = \"a\"\ntarget = \".bashrc\"\n");

    # `..` inside a path component is fine — only segment-`..` is rejected.
    _expect_ok("dotdot inside a component is fine",
        "[package]\nname = \"x\"\nversion = \"1.0\"\n[[link]]\nsource = \"a..b\"\ntarget = \"c..d\"\n");
    return 0;
}

fn test_comments_and_blanks() {
    test_group("manifest: comments and blank lines");

    var src = "# a comment\n\n[package]   # inline comment-ish, ignored\nname = \"x\"\n\n# another comment\nversion = \"1.0\"\n";
    var r = hapi_mf_parse_header_r(src, strlen(src));
    assert_eq(is_ok(r), 1, "comments do not break parsing");
    return 0;
}

fn test_parse_example_from_disk() {
    test_group("manifest: parse the shipped example");

    var r = hapi_mf_parse_file_r("docs/examples/dotfiles-zsh/hapi.cyml");
    assert_eq(is_ok(r), 1, "example parses cleanly");
    if (is_ok(r) == 1) {
        var m = load64(r + 8);
        _assert_str_eq_cstr(hapi_mf_name(m), "dotfiles-zsh", "name matches");
        assert_eq(vec_len(hapi_mf_links(m)), 3, "three links");
        assert_eq(vec_len(hapi_mf_ignore(m)), 3, "three ignore patterns");
    }
    return 0;
}

fn test_missing_file() {
    test_group("manifest: missing-file error");

    var r = hapi_mf_parse_file_r("/nonexistent/path/hapi.cyml");
    assert_eq(is_err_result(r), 1, "missing file returns Err");
    assert_eq(load64(r + 8), HapiMfIoErr, "error code is HapiMfIoErr");
    return 0;
}

# ============================================================
# M2 — link, audit, fs_link tests
# ============================================================

# Build a unique scratch directory under /tmp seeded by PID +
# a counter so successive tests don't trip over each other.
var _test_scratch_counter = 0;
fn _test_scratch_dir(): i64 {
    _test_scratch_counter = _test_scratch_counter + 1;
    var pid = syscall(SYS_GETPID);
    var buf[128];
    var prefix = "/tmp/hapi-test-";
    var plen = 15;
    memcpy(&buf, prefix, plen);
    var p = plen;
    p = p + fmt_int_buf(pid, &buf + p);
    store8(&buf + p, 45); p = p + 1;
    p = p + fmt_int_buf(_test_scratch_counter, &buf + p);
    store8(&buf + p, 0);
    var out = alloc(p + 1);
    memcpy(out, &buf, p + 1);
    sys_mkdir(out, 0x1C0);
    return out;
}

fn _test_file_size(path): i64 {
    var fd = file_open(path, 0, 0);
    if (fd < 0) { return 0; }
    var size = syscall(8, fd, 0, 2);   # lseek(fd, 0, SEEK_END)
    file_close(fd);
    return size;
}

fn _test_write_file(path, content): i64 {
    var fd = file_open(path, O_WRONLY | O_CREAT | O_TRUNC, 0x1A4);
    if (fd < 0) { return fd; }
    var n = file_write(fd, content, strlen(content));
    file_close(fd);
    return n;
}

# ------------------------------------------------------------
# fsl_compute_relative — pure-function table
# ------------------------------------------------------------

fn test_compute_relative() {
    test_group("fs_link: relative path computation");

    var r1 = fsl_compute_relative("/home/user", "/home/user/dotfiles/x");
    assert_eq(memeq(r1, "dotfiles/x", 10), 1, "from peer dir, descend in");
    assert_eq(strlen(r1), 10, "no trailing slash");

    var r2 = fsl_compute_relative("/home/user/.config", "/home/user/dotfiles/x");
    assert_eq(memeq(r2, "../dotfiles/x", 13), 1, "one up + descend");

    var r3 = fsl_compute_relative("/home/user/a/b/c", "/home/user/x");
    assert_eq(memeq(r3, "../../../x", 10), 1, "three ups + descend");

    var r4 = fsl_compute_relative("/tmp/a", "/home/user/dotfiles/x");
    assert_eq(memeq(r4, "../../home/user/dotfiles/x", 26), 1, "diverge at root");
    assert_eq(strlen(r4), 26, "diverge at root: no trailing slash");
    return 0;
}

# ------------------------------------------------------------
# audit format — JSON line shape per ADR 0002
# ------------------------------------------------------------

fn test_audit_format_link() {
    test_group("audit: link entry format");

    var buf = alloc(4096);
    var n = audit_format_link(buf, 4096,
        "pkg", "1.0.0", "sha1:deadbeef",
        "src", ".tgt",
        "/abs/src", "/abs/tgt", 0);
    assert(n > 0, "format wrote bytes");
    assert_eq(load8(buf), 123, "starts with {");
    assert_eq(load8(buf + n - 1), 10, "ends with newline");
    assert_eq(load8(buf + n - 2), 125, "closes with }");

    # Spot-check that each expected key is present.
    assert(_test_substr(buf, n, "\"op\":\"link\"") >= 0, "op:link present");
    assert(_test_substr(buf, n, "\"pkg\":\"pkg\"") >= 0, "pkg present");
    assert(_test_substr(buf, n, "\"manifest_hash\":\"sha1:deadbeef\"") >= 0, "manifest_hash present");
    assert(_test_substr(buf, n, "\"abs_target\":\"/abs/tgt\"") >= 0, "abs_target present");
    # When backup_path arg is 0, the field MUST NOT appear.
    assert(_test_substr(buf, n, "backup_path") < 0, "backup_path absent when 0");

    # And when it IS set, the field shows up at the tail.
    var buf2 = alloc(4096);
    var n2 = audit_format_link(buf2, 4096,
        "pkg", "1.0.0", "sha1:deadbeef",
        "src", ".tgt",
        "/abs/src", "/abs/tgt",
        "/var/backup/20260523-153042-pkg-foo");
    assert(_test_substr(buf2, n2, "\"backup_path\":\"/var/backup/20260523-153042-pkg-foo\"") >= 0,
           "backup_path present when set");
    return 0;
}

# Find `needle` in `haystack[0..hlen]`. Returns starting index or -1.
fn _test_substr(haystack, hlen, needle): i64 {
    var nlen = strlen(needle);
    if (nlen > hlen) { return 0 - 1; }
    var i = 0;
    while (i <= hlen - nlen) {
        if (memeq(haystack + i, needle, nlen) == 1) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

fn test_audit_escapes_quotes() {
    test_group("audit: JSON escaping");
    var buf = alloc(4096);
    var n = audit_format_link(buf, 4096,
        "pkg", "1.0", "h",
        "src", "evil\"target",          # embedded quote
        "/a/s", "/has\\back");          # embedded backslash
    assert(_test_substr(buf, n, "\\\"target") >= 0, "quote escaped");
    assert(_test_substr(buf, n, "\\\\back") >= 0, "backslash escaped");
    return 0;
}

# ------------------------------------------------------------
# link_probe classification
# ------------------------------------------------------------

fn test_link_probe() {
    test_group("fs_link: link_probe classification");

    var dir = _test_scratch_dir();
    var dlen = strlen(dir);

    # Absent
    var ap = alloc(dlen + 16);
    memcpy(ap, dir, dlen);
    memcpy(ap + dlen, "/absent\x00", 8);
    var absent = link_probe(ap);
    assert_eq(link_probe_kind(absent), HAPI_LP_ABSENT, "absent");

    # Regular file
    var fp = alloc(dlen + 16);
    memcpy(fp, dir, dlen);
    memcpy(fp + dlen, "/file\x00", 6);
    _test_write_file(fp, "hi");
    var freg = link_probe(fp);
    assert_eq(link_probe_kind(freg), HAPI_LP_FILE, "regular file");

    # Directory
    var dp = alloc(dlen + 16);
    memcpy(dp, dir, dlen);
    memcpy(dp + dlen, "/subdir\x00", 8);
    sys_mkdir(dp, 0x1C0);
    var fdir = link_probe(dp);
    assert_eq(link_probe_kind(fdir), HAPI_LP_DIRECTORY, "directory");

    # Symlink
    var sp = alloc(dlen + 16);
    memcpy(sp, dir, dlen);
    memcpy(sp + dlen, "/symlink\x00", 9);
    sys_symlink("target/x", sp);
    var fsym = link_probe(sp);
    assert_eq(link_probe_kind(fsym), HAPI_LP_SYMLINK, "symlink");
    assert_eq(memeq(link_probe_target(fsym), "target/x", 8), 1, "symlink target captured");

    return 0;
}

# ------------------------------------------------------------
# cmd_link end-to-end against an overridden scope + audit trail
# ------------------------------------------------------------

fn test_cmd_link_happy_path() {
    test_group("link: happy path + M2 acceptance (re-run is no-op)");

    var scope = _test_scratch_dir();
    var audit_path = alloc(strlen(scope) + 32);
    memcpy(audit_path, scope, strlen(scope));
    memcpy(audit_path + strlen(scope), "/audit.jsonl\x00", 13);

    link_set_scope_root(scope);
    audit_set_trail_path(audit_path);

    var rc1 = cmd_link("docs/examples/dotfiles-zsh", 0);
    assert_eq(rc1, 0, "first link succeeds");

    var size1 = _test_file_size(audit_path);
    assert(size1 > 0, "audit trail written");

    # The three expected symlinks all exist
    var z1 = alloc(strlen(scope) + 16);
    memcpy(z1, scope, strlen(scope));
    memcpy(z1 + strlen(scope), "/.zshrc\x00", 8);
    assert_eq(link_probe_kind(link_probe(z1)), HAPI_LP_SYMLINK, ".zshrc is a symlink");

    # Re-run: idempotent, no new audit lines (M2 acceptance)
    var rc2 = cmd_link("docs/examples/dotfiles-zsh", 0);
    assert_eq(rc2, 0, "re-run succeeds");
    var size2 = _test_file_size(audit_path);
    assert_eq(size2, size1, "audit trail did not grow on re-run");

    link_set_scope_root(0);
    audit_set_trail_path(0);
    return 0;
}

fn test_cmd_link_conflict_refuses() {
    test_group("link: refuses on conflict without --force");

    var scope = _test_scratch_dir();
    var audit_path = alloc(strlen(scope) + 32);
    memcpy(audit_path, scope, strlen(scope));
    memcpy(audit_path + strlen(scope), "/audit.jsonl\x00", 13);
    link_set_scope_root(scope);
    audit_set_trail_path(audit_path);

    # Plant an existing regular file at the .zshrc target.
    var conflict = alloc(strlen(scope) + 16);
    memcpy(conflict, scope, strlen(scope));
    memcpy(conflict + strlen(scope), "/.zshrc\x00", 8);
    _test_write_file(conflict, "user content");

    var rc = cmd_link("docs/examples/dotfiles-zsh", 0);
    assert_eq(rc, 1, "conflict without --force exits 1");

    # No audit writes occurred (file should not exist yet).
    assert_eq(_test_file_size(audit_path), 0, "no audit growth on refusal");

    # Original conflict file is intact (we refused, didn't touch).
    assert_eq(link_probe_kind(link_probe(conflict)), HAPI_LP_FILE, "conflict file untouched");

    # --force replaces it
    var rc_f = cmd_link("docs/examples/dotfiles-zsh", 1);
    assert_eq(rc_f, 0, "--force succeeds");
    assert_eq(link_probe_kind(link_probe(conflict)), HAPI_LP_SYMLINK, "--force replaced file with symlink");

    link_set_scope_root(0);
    audit_set_trail_path(0);
    return 0;
}

fn test_cmd_link_force_refuses_directory() {
    test_group("link: --force refuses to overwrite a directory");

    var scope = _test_scratch_dir();
    var audit_path = alloc(strlen(scope) + 32);
    memcpy(audit_path, scope, strlen(scope));
    memcpy(audit_path + strlen(scope), "/audit.jsonl\x00", 13);
    link_set_scope_root(scope);
    audit_set_trail_path(audit_path);

    # Plant a directory at the .config/zsh target.
    var cfg = alloc(strlen(scope) + 16);
    memcpy(cfg, scope, strlen(scope));
    memcpy(cfg + strlen(scope), "/.config\x00", 9);
    sys_mkdir(cfg, 0x1C0);
    var zshdir = alloc(strlen(scope) + 24);
    memcpy(zshdir, scope, strlen(scope));
    memcpy(zshdir + strlen(scope), "/.config/zsh\x00", 13);
    sys_mkdir(zshdir, 0x1C0);

    var rc = cmd_link("docs/examples/dotfiles-zsh", 1);
    assert_eq(rc, 1, "--force still refuses a directory");
    assert_eq(link_probe_kind(link_probe(zshdir)), HAPI_LP_DIRECTORY, "directory untouched");

    link_set_scope_root(0);
    audit_set_trail_path(0);
    return 0;
}

# ============================================================
# M3 — audit_reader, unlink, rollback tests
# ============================================================

# Set up a fresh scope root + audit-trail path for one test;
# returns the (scope, audit_path) tuple as a 16-byte struct.
fn _test_fresh_env(): i64 {
    var pair = alloc(16);
    var scope = _test_scratch_dir();
    var audit_path = alloc(strlen(scope) + 32);
    memcpy(audit_path, scope, strlen(scope));
    memcpy(audit_path + strlen(scope), "/audit.jsonl\x00", 13);
    link_set_scope_root(scope);
    audit_set_trail_path(audit_path);
    store64(pair, scope);
    store64(pair + 8, audit_path);
    return pair;
}

fn _test_clear_env(): i64 {
    link_set_scope_root(0);
    audit_set_trail_path(0);
    return 0;
}

# ------------------------------------------------------------
# audit_reader — round trip writer → reader
# ------------------------------------------------------------

fn test_audit_reader_roundtrip() {
    test_group("audit_reader: round trip writer → reader");

    var env = _test_fresh_env();
    var audit_path = load64(env + 8);

    audit_append_link_r("pkgA", "1.0", "sha1:aaa",
        "srcA", ".tgtA", "/abs/srcA", "/abs/tgtA");
    audit_append_link_r("pkgB", "2.0", "sha1:bbb",
        "srcB", ".tgtB", "/abs/srcB", "/abs/tgtB");
    audit_append_unlink_r("pkgA", "1.0", "sha1:aaa",
        "srcA", ".tgtA", "/abs/srcA", "/abs/tgtA");

    var entries = audit_read(audit_path);
    assert_eq(vec_len(entries), 3, "read back 3 entries");

    var e0 = vec_get(entries, 0);
    assert_eq(_har_cstr_eq(hae_op(e0), "link"), 1, "e0.op = link");
    assert_eq(_har_cstr_eq(hae_pkg(e0), "pkgA"), 1, "e0.pkg = pkgA");
    assert_eq(_har_cstr_eq(hae_target(e0), ".tgtA"), 1, "e0.target");

    var e2 = vec_get(entries, 2);
    assert_eq(_har_cstr_eq(hae_op(e2), "unlink"), 1, "e2.op = unlink");
    assert_eq(_har_cstr_eq(hae_pkg(e2), "pkgA"), 1, "e2.pkg = pkgA");

    _test_clear_env();
    return 0;
}

fn test_audit_reader_drops_torn_line() {
    test_group("audit_reader: drops trailing partial line");

    var env = _test_fresh_env();
    var audit_path = load64(env + 8);
    audit_ensure_dir();

    # Write 1.5 entries — one complete, one without trailing \n.
    var content = "{\"op\":\"link\",\"pkg\":\"a\",\"abs_target\":\"/x\"}\n{\"op\":\"link\",\"pkg\":\"b\"";
    var fd = file_open(audit_path, O_WRONLY | O_CREAT | O_TRUNC, 0x1A4);
    file_write(fd, content, strlen(content));
    file_close(fd);

    var entries = audit_read(audit_path);
    assert_eq(vec_len(entries), 1, "only the complete line is parsed");

    _test_clear_env();
    return 0;
}

fn test_audit_reader_drops_malformed() {
    test_group("audit_reader: drops malformed lines, keeps good ones");

    var env = _test_fresh_env();
    var audit_path = load64(env + 8);
    audit_ensure_dir();

    var content = "{\"op\":\"link\",\"pkg\":\"good\"}\nNOT JSON AT ALL\n{\"op\":\"unlink\",\"pkg\":\"good2\"}\n";
    var fd = file_open(audit_path, O_WRONLY | O_CREAT | O_TRUNC, 0x1A4);
    file_write(fd, content, strlen(content));
    file_close(fd);

    var entries = audit_read(audit_path);
    assert_eq(vec_len(entries), 2, "two valid lines parsed; junk dropped");

    _test_clear_env();
    return 0;
}

# ------------------------------------------------------------
# unlink — round trip (M3 acceptance)
# ------------------------------------------------------------

fn test_cmd_unlink_round_trip() {
    test_group("unlink: link → unlink round trip (M3 acceptance)");

    var env = _test_fresh_env();
    var scope = load64(env);
    var audit_path = load64(env + 8);

    assert_eq(cmd_link("docs/examples/dotfiles-zsh", 0), 0, "link succeeds");
    var size_after_link = _test_file_size(audit_path);
    assert(size_after_link > 0, "audit trail written after link");

    # Confirm symlinks exist
    var zrc = alloc(strlen(scope) + 16);
    memcpy(zrc, scope, strlen(scope));
    memcpy(zrc + strlen(scope), "/.zshrc\x00", 8);
    assert_eq(link_probe_kind(link_probe(zrc)), HAPI_LP_SYMLINK, "symlink present after link");

    assert_eq(cmd_unlink("dotfiles-zsh"), 0, "unlink succeeds");

    # All symlinks should be gone
    assert_eq(link_probe_kind(link_probe(zrc)), HAPI_LP_ABSENT, "symlink gone after unlink");

    var size_after_unlink = _test_file_size(audit_path);
    assert(size_after_unlink > size_after_link, "audit trail grew on unlink");

    # Trail now has 6 entries (3 link + 3 unlink) — the contract says
    # both ops are recorded.
    var trail = audit_read(audit_path);
    assert_eq(vec_len(trail), 6, "6 entries in trail (3 link + 3 unlink)");

    _test_clear_env();
    return 0;
}

fn test_cmd_unlink_refuses_user_mutation() {
    test_group("unlink: refuses to remove a user-modified symlink");

    var env = _test_fresh_env();
    var scope = load64(env);

    cmd_link("docs/examples/dotfiles-zsh", 0);

    # User mutates .zshrc to point somewhere else.
    var zrc = alloc(strlen(scope) + 16);
    memcpy(zrc, scope, strlen(scope));
    memcpy(zrc + strlen(scope), "/.zshrc\x00", 8);
    sys_unlink(zrc);
    sys_symlink("/tmp/elsewhere", zrc);

    var rc = cmd_unlink("dotfiles-zsh");
    assert_eq(rc, 1, "unlink exits 1 when one entry refused");

    # The user-mutated symlink is untouched.
    assert_eq(link_probe_kind(link_probe(zrc)), HAPI_LP_SYMLINK, "user-mutated symlink preserved");
    var probe = link_probe(zrc);
    assert_eq(_har_cstr_eq(link_probe_target(probe), "/tmp/elsewhere"), 1,
              "still points where user pointed it");

    # The OTHER two (unmutated) symlinks should be gone.
    var zenv = alloc(strlen(scope) + 16);
    memcpy(zenv, scope, strlen(scope));
    memcpy(zenv + strlen(scope), "/.zshenv\x00", 9);
    assert_eq(link_probe_kind(link_probe(zenv)), HAPI_LP_ABSENT,
              "unmutated symlinks still removed");

    _test_clear_env();
    return 0;
}

# ------------------------------------------------------------
# rollback — full reverse replay
# ------------------------------------------------------------

fn test_cmd_rollback_full() {
    test_group("rollback: link then rollback leaves clean state");

    var env = _test_fresh_env();
    var scope = load64(env);

    cmd_link("docs/examples/dotfiles-zsh", 0);

    var zrc = alloc(strlen(scope) + 16);
    memcpy(zrc, scope, strlen(scope));
    memcpy(zrc + strlen(scope), "/.zshrc\x00", 8);
    assert_eq(link_probe_kind(link_probe(zrc)), HAPI_LP_SYMLINK, "linked");

    assert_eq(cmd_rollback(), 0, "rollback exits 0");
    assert_eq(link_probe_kind(link_probe(zrc)), HAPI_LP_ABSENT, "symlink removed by rollback");

    _test_clear_env();
    return 0;
}

fn test_cmd_rollback_through_link_unlink_link() {
    test_group("rollback: reverses link/unlink/link to clean slate");

    var env = _test_fresh_env();
    var scope = load64(env);

    cmd_link("docs/examples/dotfiles-zsh", 0);
    cmd_unlink("dotfiles-zsh");
    cmd_link("docs/examples/dotfiles-zsh", 0);

    var zrc = alloc(strlen(scope) + 16);
    memcpy(zrc, scope, strlen(scope));
    memcpy(zrc + strlen(scope), "/.zshrc\x00", 8);
    assert_eq(link_probe_kind(link_probe(zrc)), HAPI_LP_SYMLINK, "symlink present before rollback");

    assert_eq(cmd_rollback(), 0, "rollback succeeds");
    assert_eq(link_probe_kind(link_probe(zrc)), HAPI_LP_ABSENT,
              "symlink absent after rollback through link/unlink/link");

    _test_clear_env();
    return 0;
}

fn test_cmd_rollback_idempotent() {
    test_group("rollback: running twice = same as once");

    var env = _test_fresh_env();
    var scope = load64(env);

    cmd_link("docs/examples/dotfiles-zsh", 0);
    var zrc = alloc(strlen(scope) + 16);
    memcpy(zrc, scope, strlen(scope));
    memcpy(zrc + strlen(scope), "/.zshrc\x00", 8);

    assert_eq(cmd_rollback(), 0, "first rollback");
    assert_eq(link_probe_kind(link_probe(zrc)), HAPI_LP_ABSENT, "absent after first");

    assert_eq(cmd_rollback(), 0, "second rollback");
    assert_eq(link_probe_kind(link_probe(zrc)), HAPI_LP_ABSENT, "still absent after second");

    _test_clear_env();
    return 0;
}

fn test_cmd_rollback_stops_at_marker() {
    test_group("rollback: stops at the most recent marker");

    var env = _test_fresh_env();
    var scope = load64(env);

    cmd_link("docs/examples/dotfiles-zsh", 0);
    audit_append_rollback_marker_r();
    cmd_unlink("dotfiles-zsh");

    var zrc = alloc(strlen(scope) + 16);
    memcpy(zrc, scope, strlen(scope));
    memcpy(zrc + strlen(scope), "/.zshrc\x00", 8);
    assert_eq(link_probe_kind(link_probe(zrc)), HAPI_LP_ABSENT, "unlinked before rollback");

    cmd_rollback();
    # Should reverse only the unlink (back to linked state), not the
    # original link beyond the marker.
    assert_eq(link_probe_kind(link_probe(zrc)), HAPI_LP_SYMLINK,
              "rollback re-created link (stopped at marker)");

    _test_clear_env();
    return 0;
}

# ============================================================
# M4 — adopt + rollback-of-adopt tests
# ============================================================

# Build a fresh test package in /tmp with a minimal manifest +
# one optional pre-existing link entry. Returns the package
# directory cstring.
fn _test_make_package(initial_link_source, initial_link_target): i64 {
    var pkg = _test_scratch_dir();
    var manifest_path = alloc(strlen(pkg) + 16);
    memcpy(manifest_path, pkg, strlen(pkg));
    memcpy(manifest_path + strlen(pkg), "/hapi.cyml\x00", 11);

    var manifest = alloc(512);
    var mp = 0;
    var header = "[package]\nname = \"test-pkg\"\nversion = \"0.1.0\"\n";
    memcpy(manifest + mp, header, strlen(header));
    mp = mp + strlen(header);
    if (initial_link_source != 0 && initial_link_target != 0) {
        var prefix = "\n[[link]]\nsource = \"";
        memcpy(manifest + mp, prefix, strlen(prefix)); mp = mp + strlen(prefix);
        memcpy(manifest + mp, initial_link_source, strlen(initial_link_source));
        mp = mp + strlen(initial_link_source);
        memcpy(manifest + mp, "\"\ntarget = \"", 12); mp = mp + 12;
        memcpy(manifest + mp, initial_link_target, strlen(initial_link_target));
        mp = mp + strlen(initial_link_target);
        memcpy(manifest + mp, "\"\n", 2); mp = mp + 2;
        # Also create the source file so the manifest is internally consistent.
        var sfile = alloc(strlen(pkg) + strlen(initial_link_source) + 2);
        memcpy(sfile, pkg, strlen(pkg));
        store8(sfile + strlen(pkg), 47);
        memcpy(sfile + strlen(pkg) + 1, initial_link_source, strlen(initial_link_source));
        store8(sfile + strlen(pkg) + 1 + strlen(initial_link_source), 0);
        _test_write_file(sfile, "x");
    }

    var fd = file_open(manifest_path, O_WRONLY | O_CREAT | O_TRUNC, 0x1A4);
    file_write(fd, manifest, mp);
    file_close(fd);
    return pkg;
}

# ------------------------------------------------------------
# manifest_write — append + remove a row
# ------------------------------------------------------------

fn test_manifest_append_row() {
    test_group("manifest_write: append [[link]] row");

    var pkg = _test_make_package("a", ".a");
    var manifest_path = alloc(strlen(pkg) + 16);
    memcpy(manifest_path, pkg, strlen(pkg));
    memcpy(manifest_path + strlen(pkg), "/hapi.cyml\x00", 11);

    var rc = manifest_append_link_row(manifest_path, "zshrc", ".zshrc");
    assert_eq(rc, 0, "append succeeded");

    var len = 0;
    var buf = _hmw_slurp(manifest_path, &len);
    assert(_test_substr(buf, len, "source = \"zshrc\"") >= 0, "new source present");
    assert(_test_substr(buf, len, "target = \".zshrc\"") >= 0, "new target present");
    # Original row preserved
    assert(_test_substr(buf, len, "source = \"a\"") >= 0, "original row intact");
    return 0;
}

fn test_manifest_remove_row() {
    test_group("manifest_write: remove [[link]] row");

    var pkg = _test_make_package("a", ".a");
    var manifest_path = alloc(strlen(pkg) + 16);
    memcpy(manifest_path, pkg, strlen(pkg));
    memcpy(manifest_path + strlen(pkg), "/hapi.cyml\x00", 11);

    manifest_append_link_row(manifest_path, "zshrc", ".zshrc");
    var rc = manifest_remove_link_row(manifest_path, "zshrc", ".zshrc");
    assert_eq(rc, 0, "remove succeeded");

    var len = 0;
    var buf = _hmw_slurp(manifest_path, &len);
    assert(_test_substr(buf, len, "source = \"zshrc\"") < 0, "removed source absent");
    assert(_test_substr(buf, len, "source = \"a\"") >= 0, "untouched row preserved");

    var rc2 = manifest_remove_link_row(manifest_path, "missing", ".missing");
    assert(rc2 < 0, "remove returns < 0 when row absent");
    return 0;
}

# ------------------------------------------------------------
# adopt — happy path + refusal matrix
# ------------------------------------------------------------

fn test_cmd_adopt_happy_path() {
    test_group("adopt: happy path (M4 acceptance)");

    var env = _test_fresh_env();
    var scope = load64(env);

    var pkg = _test_make_package(0, 0);
    var manifest_path = alloc(strlen(pkg) + 16);
    memcpy(manifest_path, pkg, strlen(pkg));
    memcpy(manifest_path + strlen(pkg), "/hapi.cyml\x00", 11);

    # Plant the file under the scope root.
    var src_file = alloc(strlen(scope) + 16);
    memcpy(src_file, scope, strlen(scope));
    memcpy(src_file + strlen(scope), "/.zshrc\x00", 8);
    _test_write_file(src_file, "user content");

    assert_eq(cmd_adopt(".zshrc", pkg), 0, "adopt returns 0");

    # Target is now a symlink
    var probe = link_probe(src_file);
    assert_eq(link_probe_kind(probe), HAPI_LP_SYMLINK, ".zshrc is now a symlink");

    # Source file landed in the package as "zshrc" (no leading dot)
    var pkg_src = alloc(strlen(pkg) + 16);
    memcpy(pkg_src, pkg, strlen(pkg));
    memcpy(pkg_src + strlen(pkg), "/zshrc\x00", 7);
    assert_eq(link_probe_kind(link_probe(pkg_src)), HAPI_LP_FILE, "zshrc landed in package");

    # Manifest has the new row
    var mlen = 0;
    var mbuf = _hmw_slurp(manifest_path, &mlen);
    assert(_test_substr(mbuf, mlen, "source = \"zshrc\"") >= 0, "manifest has source");
    assert(_test_substr(mbuf, mlen, "target = \".zshrc\"") >= 0, "manifest has target");

    # Audit trail has one op:adopt entry
    var audit = audit_read_default();
    assert_eq(vec_len(audit), 1, "one audit entry");
    var e0 = vec_get(audit, 0);
    assert_eq(_har_cstr_eq(hae_op(e0), "adopt"), 1, "op = adopt");

    _test_clear_env();
    return 0;
}

fn test_cmd_adopt_refuses_symlink() {
    test_group("adopt: refuses when target is already a symlink");

    var env = _test_fresh_env();
    var scope = load64(env);
    var pkg = _test_make_package(0, 0);

    var src_file = alloc(strlen(scope) + 16);
    memcpy(src_file, scope, strlen(scope));
    memcpy(src_file + strlen(scope), "/.zshrc\x00", 8);
    sys_symlink("/tmp/something", src_file);

    assert_eq(cmd_adopt(".zshrc", pkg), 1, "adopt of a symlink exits 1");
    # Symlink untouched
    assert_eq(link_probe_kind(link_probe(src_file)), HAPI_LP_SYMLINK, "symlink intact");

    _test_clear_env();
    return 0;
}

fn test_cmd_adopt_refuses_directory() {
    test_group("adopt: refuses when target is a directory");

    var env = _test_fresh_env();
    var scope = load64(env);
    var pkg = _test_make_package(0, 0);

    var dir = alloc(strlen(scope) + 16);
    memcpy(dir, scope, strlen(scope));
    memcpy(dir + strlen(scope), "/somedir\x00", 9);
    sys_mkdir(dir, 0x1C0);

    assert_eq(cmd_adopt("somedir", pkg), 1, "adopt of a directory exits 1");
    assert_eq(link_probe_kind(link_probe(dir)), HAPI_LP_DIRECTORY, "directory intact");

    _test_clear_env();
    return 0;
}

fn test_cmd_adopt_refuses_absent() {
    test_group("adopt: refuses when target is absent");

    var env = _test_fresh_env();
    var pkg = _test_make_package(0, 0);
    assert_eq(cmd_adopt(".nonexistent", pkg), 1, "adopt of absent file exits 1");
    _test_clear_env();
    return 0;
}

fn test_cmd_adopt_refuses_duplicate_target() {
    test_group("adopt: refuses when manifest already has the target");

    var env = _test_fresh_env();
    var scope = load64(env);
    # Existing row claims .zshrc
    var pkg = _test_make_package("zshrc", ".zshrc");

    var src_file = alloc(strlen(scope) + 16);
    memcpy(src_file, scope, strlen(scope));
    memcpy(src_file + strlen(scope), "/.zshrc\x00", 8);
    _test_write_file(src_file, "content");

    assert_eq(cmd_adopt(".zshrc", pkg), 1, "duplicate target refused");
    # File untouched (the manifest already had the row before we even tried)
    assert_eq(link_probe_kind(link_probe(src_file)), HAPI_LP_FILE, "file intact");

    _test_clear_env();
    return 0;
}

# ------------------------------------------------------------
# rollback over adopt — three-step reversal
# ------------------------------------------------------------

# ============================================================
# M5 — checkpoint, status, list, check --strict, sync tests
# ============================================================

fn test_cmd_sync_idempotent_clean_tree() {
    test_group("sync: clean tree -> no audit growth (M5 acceptance)");

    var env = _test_fresh_env();
    var audit_path = load64(env + 8);

    assert_eq(cmd_sync("docs/examples/dotfiles-zsh"), 0, "first sync succeeds");
    var size_after_first = _test_file_size(audit_path);
    assert(size_after_first > 0, "first sync wrote audit entries (links were created)");

    assert_eq(cmd_sync("docs/examples/dotfiles-zsh"), 0, "second sync succeeds");
    var size_after_second = _test_file_size(audit_path);
    assert_eq(size_after_second, size_after_first,
              "second sync on a clean tree produced zero audit entries");

    _test_clear_env();
    return 0;
}

fn test_cmd_sync_creates_missing_links() {
    test_group("sync: re-creates a missing link, preserves the rest");

    var env = _test_fresh_env();
    var scope = load64(env);
    var audit_path = load64(env + 8);

    cmd_link("docs/examples/dotfiles-zsh", 0);
    var size_after_link = _test_file_size(audit_path);

    # User deletes one symlink.
    var zrc = alloc(strlen(scope) + 16);
    memcpy(zrc, scope, strlen(scope));
    memcpy(zrc + strlen(scope), "/.zshrc\x00", 8);
    sys_unlink(zrc);
    assert_eq(link_probe_kind(link_probe(zrc)), HAPI_LP_ABSENT, "zshrc gone");

    assert_eq(cmd_sync("docs/examples/dotfiles-zsh"), 0, "sync exits 0");
    assert_eq(link_probe_kind(link_probe(zrc)), HAPI_LP_SYMLINK, "zshrc re-linked");

    var size_after_sync = _test_file_size(audit_path);
    assert(size_after_sync > size_after_link, "audit grew by exactly the one re-link");

    _test_clear_env();
    return 0;
}

fn test_cmd_sync_recovery_after_trail_loss() {
    test_group("sync: recovers after the audit trail is lost (drive-move scenario)");

    var env = _test_fresh_env();
    var scope = load64(env);
    var audit_path = load64(env + 8);

    # Establish the package: symlinks + trail.
    assert_eq(cmd_link("docs/examples/dotfiles-zsh", 0), 0, "initial link succeeds");
    assert(_test_file_size(audit_path) > 0, "initial link wrote audit entries");

    # Simulate a drive move that carried $HOME + the package forward
    # but wiped $XDG_STATE_HOME: the relative symlinks survive, the
    # trail is gone.
    sys_unlink(audit_path);
    assert_eq(_test_file_size(audit_path), 0, "audit trail wiped");

    var zrc = alloc(strlen(scope) + 16);
    memcpy(zrc, scope, strlen(scope));
    memcpy(zrc + strlen(scope), "/.zshrc\x00", 8);
    assert_eq(link_probe_kind(link_probe(zrc)), HAPI_LP_SYMLINK, "link survived the wipe");

    # Recovery is just a re-sync: links are already correct, so it's a
    # clean no-op that disturbs nothing.
    assert_eq(cmd_sync("docs/examples/dotfiles-zsh"), 0, "recovery sync exits 0");
    assert_eq(link_probe_kind(link_probe(zrc)), HAPI_LP_SYMLINK, "link intact after recovery sync");

    # Documented limitation, issues/2026-05-24-audit-trail-lost-on-state-dir-wipe.md:
    # an idempotent sync writes no entry, so the wiped trail is NOT
    # rebuilt to match the live links. `status` is the source of truth
    # after a state-dir loss, not `list` / `rollback`. If a future
    # reseed affordance lands, this assertion is the one to revisit.
    assert_eq(_test_file_size(audit_path), 0, "no-op recovery sync does not rebuild the trail");

    _test_clear_env();
    return 0;
}

fn test_strict_mode_rejects_unknown_section() {
    test_group("check --strict: unknown section is rejected");

    var src = "[package]\nname = \"x\"\nversion = \"1.0\"\n[weird]\nfoo = \"bar\"\n";

    # Lenient (default): parses cleanly.
    var r1 = hapi_mf_parse_header_r(src, strlen(src));
    assert_eq(is_ok(r1), 1, "lenient parser accepts unknown section");

    # Strict: rejected with HapiMfUnknownSection.
    hapi_mf_set_strict(1);
    var r2 = hapi_mf_parse_header_r(src, strlen(src));
    hapi_mf_set_strict(0);
    assert_eq(is_err_result(r2), 1, "strict parser returns Err");
    assert_eq(load64(r2 + 8), HapiMfUnknownSection, "code is HapiMfUnknownSection");
    return 0;
}

fn test_strict_mode_rejects_unknown_key() {
    test_group("check --strict: unknown key in [package] is rejected");

    var src = "[package]\nname = \"x\"\nversion = \"1.0\"\nauthor = \"me\"\n";

    var r1 = hapi_mf_parse_header_r(src, strlen(src));
    assert_eq(is_ok(r1), 1, "lenient parser tolerates `author`");

    hapi_mf_set_strict(1);
    var r2 = hapi_mf_parse_header_r(src, strlen(src));
    hapi_mf_set_strict(0);
    assert_eq(is_err_result(r2), 1, "strict parser returns Err");
    assert_eq(load64(r2 + 8), HapiMfUnknownKey, "code is HapiMfUnknownKey");
    return 0;
}

fn test_strict_mode_rejects_unknown_link_key() {
    test_group("check --strict: unknown key in [[link]] is rejected");

    var src = "[package]\nname = \"x\"\nversion = \"1.0\"\n[[link]]\nsource = \"a\"\ntarget = \".a\"\nmode = \"copy\"\n";

    var r1 = hapi_mf_parse_header_r(src, strlen(src));
    assert_eq(is_ok(r1), 1, "lenient parser tolerates `mode`");

    hapi_mf_set_strict(1);
    var r2 = hapi_mf_parse_header_r(src, strlen(src));
    hapi_mf_set_strict(0);
    assert_eq(is_err_result(r2), 1, "strict parser returns Err");
    assert_eq(load64(r2 + 8), HapiMfUnknownKey, "code is HapiMfUnknownKey");
    return 0;
}

fn test_strict_mode_accepts_clean_manifest() {
    test_group("check --strict: well-formed manifest still parses");

    var src = "[package]\nname = \"x\"\nversion = \"1.0\"\ndescription = \"d\"\nignore = [\"*.bak\"]\n[[link]]\nsource = \"a\"\ntarget = \".a\"\n";

    hapi_mf_set_strict(1);
    var r = hapi_mf_parse_header_r(src, strlen(src));
    hapi_mf_set_strict(0);
    assert_eq(is_ok(r), 1, "strict accepts fully-known schema");
    return 0;
}

fn test_cmd_check_strict_resets_flag() {
    test_group("check: --strict flag does not leak to other parsers");

