fn test_cmd_checkpoint_marker_stops_rollback() {
    test_group("checkpoint: marker bounds subsequent rollback");

    var env = _test_fresh_env();
    var scope = load64(env);

    cmd_link("docs/examples/dotfiles-zsh", 0);
    var zrc = alloc(strlen(scope) + 16);
    memcpy(zrc, scope, strlen(scope));
    memcpy(zrc + strlen(scope), "/.zshrc\x00", 8);
    assert_eq(link_probe_kind(link_probe(zrc)), HAPI_LP_SYMLINK, "linked");

    assert_eq(cmd_checkpoint(), 0, "checkpoint returns 0");

    # Trail now has 3 link entries + 1 marker.
    var trail = audit_read_default();
    assert_eq(vec_len(trail), 4, "4 entries (3 link + 1 marker)");
    var marker = vec_get(trail, 3);
    assert_eq(_har_cstr_eq(hae_op(marker), "rollback-marker"), 1, "last entry is marker");

    # Unlink after the checkpoint; rollback should reverse only
    # the unlinks (back to linked state), leaving the original
    # links beyond the marker untouched.
    cmd_unlink("dotfiles-zsh");
    assert_eq(link_probe_kind(link_probe(zrc)), HAPI_LP_ABSENT, "unlinked");

    cmd_rollback();
    assert_eq(link_probe_kind(link_probe(zrc)), HAPI_LP_SYMLINK,
              "marker bounded rollback: link restored, not chased past marker");

    _test_clear_env();
    return 0;
}

fn test_rollback_reverses_adopt() {
    test_group("rollback: reverse-adopt restores file + symlink + manifest");

    var env = _test_fresh_env();
    var scope = load64(env);
    var pkg = _test_make_package(0, 0);

    var manifest_path = alloc(strlen(pkg) + 16);
    memcpy(manifest_path, pkg, strlen(pkg));
    memcpy(manifest_path + strlen(pkg), "/hapi.cyml\x00", 11);

    var src_file = alloc(strlen(scope) + 16);
    memcpy(src_file, scope, strlen(scope));
    memcpy(src_file + strlen(scope), "/.zshrc\x00", 8);
    _test_write_file(src_file, "original user content");

    cmd_adopt(".zshrc", pkg);
    assert_eq(link_probe_kind(link_probe(src_file)), HAPI_LP_SYMLINK, "after adopt: symlink");

    assert_eq(cmd_rollback(), 0, "rollback succeeds");

    # Symlink gone, file restored as a regular file
    assert_eq(link_probe_kind(link_probe(src_file)), HAPI_LP_FILE, "file restored");

    # Source no longer in package
    var pkg_src = alloc(strlen(pkg) + 16);
    memcpy(pkg_src, pkg, strlen(pkg));
    memcpy(pkg_src + strlen(pkg), "/zshrc\x00", 7);
    assert_eq(link_probe_kind(link_probe(pkg_src)), HAPI_LP_ABSENT, "source absent from package");

    # Manifest row gone
    var mlen = 0;
    var mbuf = _hmw_slurp(manifest_path, &mlen);
    assert(_test_substr(mbuf, mlen, "source = \"zshrc\"") < 0, "manifest row removed");

    _test_clear_env();
    return 0;
}

# ============================================================
# M6 — capability gate + --dry-run tests
# ============================================================

fn test_cap_path_within_basics() {
    test_group("cap: path-within prefix matcher");

    # Exact match.
    assert_eq(_cap_path_within("/etc/myproject", "/etc/myproject"), 1, "exact match");

    # Subdir match.
    assert_eq(_cap_path_within("/etc/myproject/sub", "/etc/myproject"), 1, "subdir match");

    # Multi-level subdir.
    assert_eq(_cap_path_within("/etc/myproject/a/b/c", "/etc/myproject"), 1, "deep subdir match");

    # Prefix-byte-collision but different path component — must not match.
    assert_eq(_cap_path_within("/etc/myprojectextra", "/etc/myproject"), 0,
              "byte-prefix collision rejected (boundary on /)");

    # Trailing slash on prefix is tolerated.
    assert_eq(_cap_path_within("/etc/myproject/foo", "/etc/myproject/"), 1,
              "trailing slash on prefix tolerated");

    # Parent path, not within child prefix.
    assert_eq(_cap_path_within("/etc", "/etc/myproject"), 0, "parent != within child");

    # Empty prefix never matches.
    assert_eq(_cap_path_within("/etc", ""), 0, "empty prefix rejected");
    return 0;
}

fn test_cap_check_denies_outside_home_and_allowlist() {
    test_group("cap: denies path outside $HOME and HAPI_ALLOWED_ROOTS");

    cap_set_home("/home/macro");
    cap_set_allowlist(0);
    var r = cap_check_root_r("/etc/myproject");
    assert_eq(is_err_result(r), 1, "denied when no allowlist + outside home");
    assert_eq(load64(r + 8), HapiCapDenied, "code is HapiCapDenied");
    cap_set_home(0);
    return 0;
}

fn test_cap_check_allows_inside_home() {
    test_group("cap: allows paths inside $HOME implicitly");

    cap_set_home("/home/macro");
    cap_set_allowlist(0);
    var r = cap_check_root_r("/home/macro/projects/x");
    assert_eq(is_ok(r), 1, "inside-home path allowed without allowlist entry");
    cap_set_home(0);
    return 0;
}

fn test_cap_check_allows_listed_root() {
    test_group("cap: allows path matching HAPI_ALLOWED_ROOTS");

    cap_set_home("/home/macro");
    cap_set_allowlist("/etc/myproject:/srv/app");
    var r = cap_check_root_r("/etc/myproject");
    assert_eq(is_ok(r), 1, "exact-match allowlist entry passes");

    var r2 = cap_check_root_r("/srv/app/sub/path");
    assert_eq(is_ok(r2), 1, "subdir of allowlist entry passes");

    var r3 = cap_check_root_r("/etc/myprojectextra");
    assert_eq(is_err_result(r3), 1, "byte-prefix collision still denied");

    var r4 = cap_check_root_r("/tmp/random");
    assert_eq(is_err_result(r4), 1, "non-listed path denied");

    cap_set_home(0);
    cap_set_allowlist(0);
    return 0;
}

