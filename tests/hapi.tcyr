# ============================================================
# M7 — security hardening repairs (v0.9.0 audit pass)
# ============================================================

fn test_lexical_normalize_dotdot_collapses() {
    test_group("audit-repair: lexical normalize collapses ..");

    # /home/user/../etc/secret — `..` pops "user", leaving
    # [home, etc, secret]. The bypass demo it defeats:
    # this path is no longer byte-prefix-matchable to /home/user,
    # so cap_check_root_r denies it (see test below).
    var a = fsl_lexical_normalize("/home/user/../etc/secret");
    assert_eq(memeq(a, "/home/etc/secret", 16), 1, ".. pops one component");
    assert_eq(strlen(a), 16, "no trailing junk");

    var b = fsl_lexical_normalize("/a/b/c/../../d");
    assert_eq(memeq(b, "/a/d", 4), 1, "successive .. pops two");
    assert_eq(strlen(b), 4, "no trailing junk");

    var c = fsl_lexical_normalize("/a/./b/./");
    assert_eq(memeq(c, "/a/b", 4), 1, ". segments dropped");
    assert_eq(strlen(c), 4, "no trailing junk");

    var d = fsl_lexical_normalize("/..");
    assert_eq(memeq(d, "/", 1), 1, ".. at root stays at root");
    assert_eq(strlen(d), 1, "root is one byte");

    var e = fsl_lexical_normalize("/");
    assert_eq(memeq(e, "/", 1), 1, "root canonicalizes to root");
    assert_eq(strlen(e), 1, "root is one byte");

    return 0;
}

fn test_cap_check_rejects_dotdot_escape() {
    test_group("audit-repair: cap check rejects .. that escapes $HOME");

    cap_set_home("/home/user");
    cap_set_allowlist("");

    # The bypass case: /home/user/../etc looks like it starts
    # with /home/user but actually resolves to /etc.
    var r = cap_check_root_r("/home/user/../etc");
    assert_eq(is_err_result(r), 1, "escape via .. is denied");

    # Legitimate under-$HOME path still allowed.
    var r2 = cap_check_root_r("/home/user/dotfiles");
    assert_eq(is_ok(r2), 1, "honest subpath still allowed");

    # And $HOME itself.
    var r3 = cap_check_root_r("/home/user");
    assert_eq(is_ok(r3), 1, "$HOME itself still allowed");

    cap_set_home(0);
    cap_set_allowlist(0);
    return 0;
}

fn test_cap_check_normalizes_allowlist_entries() {
    test_group("audit-repair: allowlist entries lex-normalized too");

    cap_set_home("/dev/null");   # force allowlist path
    cap_set_allowlist("/etc/myproject/../escape:/srv/legit");

    # The malformed entry must not gate access to /escape via
    # byte-prefix match — the entry normalizes to /escape, so
    # paths under /escape pass, but /etc/myproject paths do NOT.
    var r1 = cap_check_root_r("/etc/myproject/anything");
    assert_eq(is_err_result(r1), 1, "malformed allowlist entry no longer gates /etc/myproject");

    var r2 = cap_check_root_r("/srv/legit/sub");
    assert_eq(is_ok(r2), 1, "honest allowlist entry still works");

    cap_set_home(0);
    cap_set_allowlist(0);
    return 0;
}

fn test_backup_copy_refuses_symlink_source() {
    test_group("audit-repair: backup_copy fails on symlink source (TOCTOU defense)");

    var scratch = _test_scratch_dir();

    # Plant a regular file and a symlink to it. The probe step
    # in cmd_link / cmd_adopt would only ever pass us a regular
    # file path — but the kernel-level O_NOFOLLOW means even if
    # an attacker races a swap, we refuse rather than copy
    # through the symlink.
    var real = alloc(strlen(scratch) + 16);
    memcpy(real, scratch, strlen(scratch));
    memcpy(real + strlen(scratch), "/real\x00", 6);
    _test_write_file(real, "secret bytes");

    var link = alloc(strlen(scratch) + 16);
    memcpy(link, scratch, strlen(scratch));
    memcpy(link + strlen(scratch), "/link\x00", 6);
    sys_symlink(real, link);

    var dst = alloc(strlen(scratch) + 16);
    memcpy(dst, scratch, strlen(scratch));
    memcpy(dst + strlen(scratch), "/copy\x00", 6);

    var rc = hapi_backup_copy(link, dst);
    assert(rc < 0, "copy through symlink refused");

    # Direct (non-symlink) copy still works.
    var rc2 = hapi_backup_copy(real, dst);
    assert_eq(rc2, 0, "regular-file copy succeeds");

    return 0;
}

# ============================================================
# M7 — manifest-hash canonicalization (sha1: → sha1c:)
# ============================================================

# Hash the canonical form of a literal manifest source. Returns
# a heap cstring "sha1c:" + 40 hex on success, 0 on parse failure.
fn _test_canonical_hash_of(src): i64 {
    var r = hapi_mf_parse_header_r(src, strlen(src));
    if (is_err_result(r) == 1) { return 0; }
    var m = load64(r + 8);
    var buf = alloc(65536);
    var n = hapi_mf_canonicalize(m, buf, 65536);
    var digest[20];
    sha1(buf, n, &digest);
    var out = alloc(47);
    var prefix = "sha1c:";
    memcpy(out, prefix, 6);
    var i = 0;
    while (i < 20) {
        var b = load8(&digest + i);
        var hi = b / 16;
        var lo = b - hi * 16;
        if (hi < 10) { store8(out + 6 + i * 2, 48 + hi); }
        else { store8(out + 6 + i * 2, 87 + hi); }
        if (lo < 10) { store8(out + 6 + i * 2 + 1, 48 + lo); }
        else { store8(out + 6 + i * 2 + 1, 87 + lo); }
        i = i + 1;
    }
    store8(out + 46, 0);
    return out;
}

fn _test_cstr_eq(a, b): i64 {
    var la = strlen(a);
    var lb = strlen(b);
    if (la != lb) { return 0; }
    return memeq(a, b, la);
}

fn test_canonical_hash_prefix() {
    test_group("canonical: writer emits sha1c: prefix");

    # Use the shipped example manifest so we don't depend on a
    # filesystem path that may not exist in CI.
    var h = audit_manifest_hash("docs/examples/dotfiles-zsh/hapi.cyml");
    assert(h != 0, "hash computed");
    # Must start with "sha1c:" — 6 bytes.
    var prefix = "sha1c:";
    assert_eq(memeq(h, prefix, 6), 1, "prefix is sha1c:");
    assert_eq(strlen(h), 46, "total length is sha1c: + 40 hex chars");
    return 0;
}

fn test_canonical_hash_ignores_comments_and_whitespace() {
    test_group("canonical: cosmetic edits collide");

    var a = "[package]\nname = \"x\"\nversion = \"1.0\"\n[[link]]\nsource = \"s\"\ntarget = \".t\"\n";
    var b = "# a leading comment\n\n[package]\n   # inline   \nname    =    \"x\"\nversion = \"1.0\"\n\n\n[[link]]\nsource = \"s\"\ntarget = \".t\"\n\n";
    var ha = _test_canonical_hash_of(a);
    var hb = _test_canonical_hash_of(b);
    assert(ha != 0, "a hashes");
    assert(hb != 0, "b hashes");
    assert_eq(_test_cstr_eq(ha, hb), 1, "comments + whitespace yield identical hash");
    return 0;
}

fn test_canonical_hash_row_reorder_collides() {
    test_group("canonical: row order does not affect hash");

    var a = "[package]\nname = \"x\"\nversion = \"1.0\"\n[[link]]\nsource = \"a\"\ntarget = \".a\"\n[[link]]\nsource = \"b\"\ntarget = \".b\"\n";
    var b = "[package]\nname = \"x\"\nversion = \"1.0\"\n[[link]]\nsource = \"b\"\ntarget = \".b\"\n[[link]]\nsource = \"a\"\ntarget = \".a\"\n";
    var ha = _test_canonical_hash_of(a);
    var hb = _test_canonical_hash_of(b);
    assert_eq(_test_cstr_eq(ha, hb), 1, "rows reordered yield identical hash");
    return 0;
}

fn test_canonical_hash_value_change_diverges() {
    test_group("canonical: semantic edit changes the hash");

    var a = "[package]\nname = \"x\"\nversion = \"1.0\"\n[[link]]\nsource = \"s\"\ntarget = \".t\"\n";
    var b = "[package]\nname = \"x\"\nversion = \"1.0\"\n[[link]]\nsource = \"s\"\ntarget = \".u\"\n";
    var ha = _test_canonical_hash_of(a);
    var hb = _test_canonical_hash_of(b);
    assert_eq(_test_cstr_eq(ha, hb), 0, "target rename produces a different hash");
    return 0;
}

# ============================================================
# M7 — --backup-to (link --force / sync / adopt snapshots)
# ============================================================

fn test_backup_compose_path_shape() {
    test_group("backup: compose_path filename layout");
    var p = hapi_backup_compose_path("/var/backup", "myPkg", "/home/user/.zshrc");
    var n = strlen(p);
    # Must start with "/var/backup/<15 ts chars>-myPkg-.zshrc".
    assert(_test_substr(p, n, "/var/backup/") == 0, "starts with dir + slash");
    assert(_test_substr(p, n, "-myPkg-.zshrc") >= 0, "carries pkg + basename");
    # Single trailing slash on the dir collapses to one separator.
    var p2 = hapi_backup_compose_path("/var/backup/", "pkg", "/x/y");
    var n2 = strlen(p2);
    assert(_test_substr(p2, n2, "/var/backup//") < 0, "no doubled slash");
    return 0;
}

fn test_backup_to_link_force_snapshots_file() {
    test_group("backup: link --force snapshots existing file");

    var env = _test_fresh_env();
    var scope = load64(env);
    var audit_path = load64(env + 8);

    # Plant a conflicting file with known content at .zshrc.
    var tgt = alloc(strlen(scope) + 16);
    memcpy(tgt, scope, strlen(scope));
    memcpy(tgt + strlen(scope), "/.zshrc\x00", 8);
    _test_write_file(tgt, "user content");

    # Backup dir under the scratch dir.
    var bdir = alloc(strlen(scope) + 16);
    memcpy(bdir, scope, strlen(scope));
    memcpy(bdir + strlen(scope), "/backups\x00", 9);
    hapi_set_backup_dir(bdir);

    var rc = cmd_link("docs/examples/dotfiles-zsh", 1);
    assert_eq(rc, 0, "link --force succeeds with --backup-to");
    hapi_set_backup_dir(0);

    # Target should now be a symlink.
    assert_eq(link_probe_kind(link_probe(tgt)), HAPI_LP_SYMLINK,
              "target is now a symlink");

    # Find the backup_path in the audit trail and read it back.
    var entries = audit_read(audit_path);
    var found_backup = 0;
    var found_content = 0;
    var i = 0;
    while (i < vec_len(entries)) {
        var e = vec_get(entries, i);
        var bp = hae_backup_path(e);
        var t = hae_target(e);
        if (bp != 0 && t != 0 && _har_cstr_eq(t, ".zshrc") == 1) {
            found_backup = 1;
            var rbuf = alloc(4096);
            var rn = file_read_all(bp, rbuf, 4096);
            if (rn == 12 && memeq(rbuf, "user content", 12) == 1) {
                found_content = 1;
            }
        }
        i = i + 1;
    }
    assert_eq(found_backup, 1, "audit entry carries backup_path");
    assert_eq(found_content, 1, "backup file holds original bytes");

    _test_clear_env();
    return 0;
}

fn test_backup_to_skips_symlink_conflict() {
    test_group("backup: --backup-to does not snapshot symlink conflicts");

    var env = _test_fresh_env();
    var scope = load64(env);

    # Plant a symlink-to-elsewhere at .zshrc (no file bytes to save).
    var tgt = alloc(strlen(scope) + 16);
    memcpy(tgt, scope, strlen(scope));
    memcpy(tgt + strlen(scope), "/.zshrc\x00", 8);
    sys_symlink("/tmp/elsewhere", tgt);

    var bdir = alloc(strlen(scope) + 16);
    memcpy(bdir, scope, strlen(scope));
    memcpy(bdir + strlen(scope), "/backups\x00", 9);
    hapi_set_backup_dir(bdir);

    assert_eq(cmd_link("docs/examples/dotfiles-zsh", 1), 0, "link --force succeeds");
    hapi_set_backup_dir(0);

    # No backup directory should have been created — symlink
    # conflicts skip the snapshot.
    assert_eq(link_probe_kind(link_probe(bdir)), HAPI_LP_ABSENT,
              "backup dir untouched (no file conflict)");

    _test_clear_env();
    return 0;
}

fn test_backup_to_dry_run_writes_no_backup() {
    test_group("backup: dry-run does not write the snapshot");

    var env = _test_fresh_env();
    var scope = load64(env);

    var tgt = alloc(strlen(scope) + 16);
    memcpy(tgt, scope, strlen(scope));
    memcpy(tgt + strlen(scope), "/.zshrc\x00", 8);
    _test_write_file(tgt, "user content");

    var bdir = alloc(strlen(scope) + 16);
    memcpy(bdir, scope, strlen(scope));
    memcpy(bdir + strlen(scope), "/backups\x00", 9);
    hapi_set_backup_dir(bdir);

    hapi_set_dry_run(1);
    assert_eq(cmd_link("docs/examples/dotfiles-zsh", 1), 0, "dry-run --force succeeds");
    hapi_set_dry_run(0);
    hapi_set_backup_dir(0);

    # Backup dir not created under dry-run; the conflict file is
    # still in place (no unlink happened).
    assert_eq(link_probe_kind(link_probe(bdir)), HAPI_LP_ABSENT,
              "no backup dir under dry-run");
    assert_eq(link_probe_kind(link_probe(tgt)), HAPI_LP_FILE,
              "conflict file untouched under dry-run");

    _test_clear_env();
    return 0;
}

fn test_backup_to_adopt_snapshots_before_rename() {
    test_group("backup: adopt snapshots before sys_rename");

    var env = _test_fresh_env();
    var scope = load64(env);
    var audit_path = load64(env + 8);

    # Plant the file to adopt with known bytes.
    var tgt = alloc(strlen(scope) + 16);
    memcpy(tgt, scope, strlen(scope));
    memcpy(tgt + strlen(scope), "/.zshrc\x00", 8);
    _test_write_file(tgt, "user content");

    # Fresh package dir.
    var pkg = _test_make_package("a", ".a");
    var bdir = alloc(strlen(scope) + 16);
    memcpy(bdir, scope, strlen(scope));
    memcpy(bdir + strlen(scope), "/backups\x00", 9);

    hapi_set_backup_dir(bdir);
    var rc = cmd_adopt(".zshrc", pkg);
    hapi_set_backup_dir(0);
    assert_eq(rc, 0, "adopt with --backup-to succeeds");

    # Audit entry should carry backup_path on the op:adopt row.
    var entries = audit_read(audit_path);
    var found = 0;
    var i = 0;
    while (i < vec_len(entries)) {
        var e = vec_get(entries, i);
        var op = hae_op(e);
        var bp = hae_backup_path(e);
        if (op != 0 && _har_cstr_eq(op, "adopt") == 1 && bp != 0) {
            var rbuf = alloc(4096);
            var rn = file_read_all(bp, rbuf, 4096);
            if (rn == 12 && memeq(rbuf, "user content", 12) == 1) { found = 1; }
        }
        i = i + 1;
    }
    assert_eq(found, 1, "adopt audit entry carries a readable backup_path");

    _test_clear_env();
    return 0;
}

