    audit_append_link_r("pkgB", "1.0", "h", "b", ".b", "/abs/b", "/abs/tb");
    audit_append_link_r("pkgA", "1.0", "h", "c", ".c", "/abs/c", "/abs/tc");

    var trail = audit_read_default();
    var pkgs = _hls_unique_pkgs(trail);
    assert_eq(vec_len(pkgs), 2, "two unique packages");
    assert_eq(_hls_cstr_eq(vec_get(pkgs, 0), "pkgA"), 1, "pkgA first-seen");
    assert_eq(_hls_cstr_eq(vec_get(pkgs, 1), "pkgB"), 1, "pkgB next");

    _test_clear_env();
